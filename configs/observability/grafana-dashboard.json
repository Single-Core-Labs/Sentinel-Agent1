{
  "title": "Platform Agent — Observability",
  "uid": "platform-agent-observability",
  "tags": ["platform-agent", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "LLM Call Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(agent_llm_call_count_total[5m]))",
        "legendFormat": "calls/s"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "title": "Tool Call Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 3, "y": 0 },
      "targets": [{
        "expr": "sum(rate(agent_tool_call_count_total[5m]))",
        "legendFormat": "calls/s"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 30 }
          ]}
        }
      }
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 0 },
      "targets": [{
        "expr": "sum(rate(agent_session_count_total[5m]))",
        "legendFormat": "sessions"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]}
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 9, "y": 0 },
      "targets": [{
        "expr": "sum(rate(agent_error_count_total[5m]))",
        "legendFormat": "errors/s"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.1 }
          ]}
        }
      }
    },
    {
      "title": "LLM Duration — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(agent_llm_call_duration_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(agent_llm_call_duration_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(agent_llm_call_duration_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Calls by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 6 },
      "targets": [{
        "expr": "sum by (model) (rate(agent_llm_call_count_total[5m]))",
        "legendFormat": "__auto"
      }],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "options": {
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "/.*/" },
        "legend": { "show": true, "values": true }
      }
    },
    {
      "title": "LLM Calls by Kind",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 6 },
      "targets": [{
        "expr": "sum by (kind) (rate(agent_llm_call_count_total[5m]))",
        "legendFormat": "__auto"
      }],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "options": {
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "/.*/" },
        "legend": { "show": true, "values": true }
      }
    },
    {
      "title": "Token Usage — Input vs Output",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 14 },
      "targets": [
        { "expr": "sum by (token_type) (rate(agent_llm_token_usage_total{token_type=\"input\"}[5m]))", "legendFormat": "input" },
        { "expr": "sum by (token_type) (rate(agent_llm_token_usage_total{token_type=\"output\"}[5m]))", "legendFormat": "output" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s",
          "custom": { "showPoints": "never" }
        }
      },
      "stack": { "mode": "normal" }
    },
    {
      "title": "Token Breakdown by Model",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 14 },
      "targets": [{
        "expr": "sum by (model) (rate(agent_llm_token_usage_total[5m]))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "tok/s",
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "title": "Cache Efficiency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 14 },
      "targets": [{
        "expr": "sum(rate(agent_llm_token_usage_total{token_type=\"cache\"}[5m])) / sum(rate(agent_llm_token_usage_total[5m])) * 100",
        "legendFormat": "cache %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Tool Duration — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(agent_tool_call_duration_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(agent_tool_call_duration_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(agent_tool_call_duration_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Tool Calls by Name",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 22 },
      "targets": [{
        "expr": "topk(15, sum by (tool_name) (rate(agent_tool_call_count_total[5m])))",
        "legendFormat": "{{tool_name}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "cps", "min": 0 }
      },
      "options": {
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "title": "Tool Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 22 },
      "targets": [{
        "expr": "sum(rate(agent_tool_call_count_total{tool_type=\"builtin\"}[5m]))",
        "legendFormat": "builtin"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Errors by Type",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 30 },
      "targets": [{
        "expr": "sum by (error_type) (rate(agent_error_count_total[15m]))",
        "legendFormat": "{{error_type}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "cps", "min": 0 }
      },
      "options": {
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "title": "LLM Cost Estimate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 3, "x": 6, "y": 30 },
      "targets": [{
        "expr": "sum(rate(agent_llm_call_count_total[1h])) * 0.003",
        "legendFormat": "$/h est."
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "USD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.10 }
          ]}
        }
      }
    },
    {
      "title": "Traces (Tempo)",
      "type": "tempo",
      "gridPos": { "h": 8, "w": 3, "x": 9, "y": 30 },
      "datasource": "tempo",
      "targets": [{
        "query": "{.service_name = \"platform-agent\"}",
        "queryType": "nativeSearch"
      }],
      "options": {
        "serviceMap": { "show": false },
        "spanBar": { "show": true, "type": "duration" }
      }
    }
  ],
  "rows": []
}
