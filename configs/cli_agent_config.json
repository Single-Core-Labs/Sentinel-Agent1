{
  "model_name": "zai-org/GLM-5.2:novita",
  "save_sessions": true,
  "session_dataset_repo": "smolagents/sentinel-ai-sessions",
  "share_traces": true,
  "yolo_mode": false,
  "confirm_cpu_jobs": true,
  "auto_file_upload": true,
  "tool_runtime": "local",
  "messaging": {
    "enabled": false,
    "auto_event_types": ["approval_required", "error", "turn_complete"],
    "destinations": {}
  },
  "mcpServers": {
    "hf-mcp-server": {
      "transport": "http",
      "url": "https://platformops.co/mcp?login"
    },
    "terraform": {
      "command": "npx",
      "args": ["-y", "terraform-mcp-server"]
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana", "--disable-write"],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL:-http://localhost:3000}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "opentelemetry": {
      "command": "npx",
      "args": ["-y", "@traceloop/opentelemetry-mcp"],
      "env": {
        "OTEL_ENDPOINT": "${OTEL_ENDPOINT:-http://localhost:16686}",
        "JAEGER_ENDPOINT": "${JAEGER_ENDPOINT:-http://localhost:16686}",
        "TEMPO_ENDPOINT": "${TEMPO_ENDPOINT}"
      }
    }
  },
  "model_routing": {
    "cheap_model": "zai-org/GLM-5.2:novita",
    "strong_model": "zai-org/GLM-5.2:novita"
  }
}
