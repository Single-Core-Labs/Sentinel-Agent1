{
  "name": "Sentinel AI — Secure (Network-Restricted)",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "1.85.0",
      "profile": "complete"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "ms-python.python",
        "bazelbuild.vscode-bazel"
      ],
      "settings": {
        "rust-analyzer.cargo.features": "all",
        "rust-analyzer.check.command": "clippy"
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/init-firewall.sh && python3 .devcontainer/post_install.py",
  "mounts": [
    "source=sentinel-bashhistory-secure,target=/commandhistory,type=volume",
    "source=sentinel-cargocache-secure,target=/usr/local/cargo/registry,type=volume"
  ],
  "remoteUser": "vscode",
  "containerEnv": {
    "SENTINEL_DEVCONTAINER": "1",
    "SENTINEL_SECURE": "1",
    "SENTINEL_SANDBOX_BWRAP": "/usr/bin/bwrap",
    "CARGO_NET_GIT_FETCH_WITH_CLI": "true"
  },
  "securityOpt": ["seccomp=unconfined"],
  "capAdd": ["NET_ADMIN", "SYS_ADMIN"]
}
