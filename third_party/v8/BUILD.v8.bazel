"""Build rules for V8 / rusty_v8.

Manages versioning, platform-specific binaries, and custom C++ standard
library integration (libc++, libcxxabi, llvm-libc).
"""

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_import")

cc_library(
    name = "v8",
    visibility = ["//visibility:public"],
    deps = select({
        "@platforms//os:linux": ["@rusty_v8//:v8_linux"],
        "@platforms//os:macos": ["@rusty_v8//:v8_macos"],
        "@platforms//os:windows": ["@rusty_v8//:v8_windows"],
    }),
)

cc_library(
    name = "libcxx",
    visibility = ["//visibility:public"],
    deps = [
        "@rusty_v8_libcxx//:libcxx",
        "@rusty_v8_libcxxabi//:libcxxabi",
        "@rusty_v8_llvm_libc//:llvm_libc",
    ],
)

filegroup(
    name = "v8_headers",
    srcs = glob(["include/**/*.h"]),
    visibility = ["//visibility:public"],
)
