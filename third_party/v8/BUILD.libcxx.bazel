"""Build rules for libc++ — LLVM's C++ standard library (Chromium fork).

This BUILD file is used by the `@rusty_v8_libcxx` http_archive repository.
It exposes the libc++ headers and static library needed by rusty_v8 on
Linux.

The Chromium fork of libc++ adds V8-specific optimisations:
  - `_LIBCPP_ABI_VERSION` = 2 (new ABI)
  - `_LIBCPP_HAS_NO_VENDOR_AVAILABILITY` (no availability attributes)
  - Inlined shared_ptr and string operations tuned for V8's allocation
    patterns.

Headers are patched with a `__config_site` generated by V8's build system
(see //third_party/v8/libcxx_config).
"""

load("@rules_cc//cc:defs.bzl", "cc_library")

licenses(["notice"])

_V8_LIBCXX_COPTS = [
    "-D_LIBCPP_ABI_VERSION=2",
    "-D_LIBCPP_HAS_NO_VENDOR_AVAILABILITY",
    "-D_LIBCPP_ENABLE_NODISCARD",
    "-D_LIBCPP_DISABLE_AVAILABILITY",
    "-D_LIBCPP_HAS_NO_LIBRARY_ALIGNED_ALLOCATION",
]

cc_library(
    name = "libcxx",
    hdrs = glob(
        include = [
            "include/**/*.h",
            "include/**/*.hpp",
        ],
    ),
    includes = [
        "include",
        "include/c++/v1",
    ],
    copts = _V8_LIBCXX_COPTS,
    defines = [
        "_LIBCPP_ABI_VERSION=2",
        "_LIBCPP_HAS_NO_VENDOR_AVAILABILITY",
    ],
    linkopts = select({
        "@platforms//os:linux": [
            "-lrt",
            "-lpthread",
            "-ldl",
        ],
        "//conditions:default": [],
    }),
    textual_hdrs = glob([
        "include/**/*.impl.h",
        "include/**/*.h",
    ]),
    visibility = ["//visibility:public"],
    deps = [
        "@//third_party/v8/libcxx_config:libcxx_config",
    ],
)

# Static library variant — for fully hermetic builds
cc_library(
    name = "libcxx_static",
    srcs = glob([
        "src/**/*.cpp",
        "src/**/*.h",
    ], exclude = [
        "src/**/experimental/**",
        "src/**/filesystem/**",
    ]),
    hdrs = glob(["include/**/*.h"]),
    includes = [
        "include",
        "include/c++/v1",
    ],
    copts = _V8_LIBCXX_COPTS,
    defines = [
        "_LIBCPP_ABI_VERSION=2",
        "_LIBCPP_HAS_NO_VENDOR_AVAILABILITY",
        "_LIBCPP_BUILDING_LIBRARY",
    ],
    linkopts = select({
        "@platforms//os:linux": [
            "-lrt",
            "-lpthread",
            "-ldl",
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
