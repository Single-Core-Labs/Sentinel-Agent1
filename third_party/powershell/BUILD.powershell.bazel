"""Build rules for PowerShell (Windows)."""

load("@rules_cc//cc:defs.bzl", "cc_binary")

exports_files(["pwsh.exe"])

filegroup(
    name = "powershell_binaries",
    srcs = glob(["**/*"]),
    visibility = ["//visibility:public"],
)

sh_binary(
    name = "pwsh",
    srcs = ["pwsh.exe"],
    visibility = ["//visibility:public"],
)
